{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "reply": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["continue", "needs_input", "ready_for_review", "finish"]
    },
    "finish": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "summary": { "type": "string" },
        "resultTitle": { "type": "string" },
        "needsReview": { "type": "boolean" }
      },
      "required": ["summary", "resultTitle", "needsReview"]
    }
  },
  "required": ["reply", "status", "finish"]
}
